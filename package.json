{
    "name": "vjscript",
    "version": "0.2.4",
    "description": "Framework that automagically translates your JavaScript code to VScript supported Squirrel language.",
    "main": "dist/index.js",
    "author": "Moonly Days",
    "license": "ISC",
    "bugs": {
        "url": "https://github.com/MoonlyDays/VJScript/issues"
    },
    "homepage": "https://github.com/MoonlyDays/VJScript#readme",
    "keywords": [
        "vscript",
        "squirrel",
        "javascript"
    ],
    "exports": {
        ".": {
            "import": {
                "default": "./dist/index.js",
                "types": "./dist/index.d.ts"
            }
        }
    },
    "files": [
        "dist",
        "types",
        "polyfill/*.js",
        "polyfill/*.nut",
        "package.json"
    ],
    "scripts": {
        "prepack": "npm run build",
        "test": "node dist/vjsc.js test/code.js -t",
        "test_watch": "node dist/vjsc.js test/code.js -t -w -i 100",
        "watch": "tsc -w",
        "build": "tsc",
        "dev": "npx ts-node src/vjsc.ts"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/MoonlyDays/VJScript.git"
    },
    "bin": {
        "vjsc": "./dist/vjsc.js"
    },
    "devDependencies": {
        "@types/babel__core": "^7.20.5",
        "@types/estree": "^1.0.9",
        "@typescript-eslint/eslint-plugin": "^8.60.1",
        "@typescript-eslint/parser": "^8.60.1",
        "eslint": "^10.4.1",
        "eslint-plugin-simple-import-sort": "^13.0.0",
        "ts-node": "^10.9.2",
        "typescript": "^6.0.3"
    },
    "dependencies": {
        "@babel/core": "^7.29.7",
        "@babel/plugin-transform-modules-commonjs": "^7.29.7",
        "babel-plugin-transform-undefined-to-void": "^6.9.4",
        "estree-toolkit": "^1.7.14",
        "meriyah": "^7.1.0"
    }
}
